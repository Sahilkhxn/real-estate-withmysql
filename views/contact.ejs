<%- include('partials/header', { title: 'Contact Us' }) %>

<section class="page-section">
  <div class="container" style="max-width:820px">
    <div class="section-header">
      <div>
        <span class="section-title">Contact Us</span>
      </div>
    </div>

    <div style="line-height:1.8; color:var(--text-secondary, #444); font-size:0.98rem">
      <p style="margin-bottom:24px">
        Have a question about a listing, want to report an issue, or interested in listing your
        property with us? Reach out through any of the channels below.
      </p>

      <div style="display:grid; gap:16px; max-width:420px">
        <div style="background:#f7f8fa; border:1px solid #eee; border-radius:12px; padding:18px 20px">
          <div style="font-weight:700; font-size:0.85rem; color:#888; margin-bottom:4px">EMAIL</div>
          <a href="mailto:inquiry@webjinny.xyz" style="color:var(--primary, #002FA7); font-weight:600; font-size:1rem">
            inquiry@webjinny.xyz
          </a>
        </div>

        <div style="background:#f7f8fa; border:1px solid #eee; border-radius:12px; padding:18px 20px">
          <div style="font-weight:700; font-size:0.85rem; color:#888; margin-bottom:4px">RESPONSE TIME</div>
          <div style="font-size:1rem">We usually reply within 24–48 hours.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
