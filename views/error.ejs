<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Error | Webjinny</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<div style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px;text-align:center;background:var(--bg-page)">
  <div style="font-size:5rem;margin-bottom:16px">🏚️</div>
  <h1 style="font-size:2rem;font-weight:800;color:var(--blue-primary);margin-bottom:8px">Oops!</h1>
  <p style="color:var(--text-mid);font-size:1.05rem;margin-bottom:28px"><%= message || 'Something went wrong.' %></p>
  <a href="/" class="btn btn-primary btn-lg">← Go Home</a>
</div>
</body>
</html>
