<%- include('partials/header', { title: 'Privacy Policy' }) %>

<section class="page-section">
  <div class="container" style="max-width:820px">
    <div class="section-header">
      <div>
        <span class="section-title">Privacy Policy</span>
      </div>
    </div>

    <div style="line-height:1.8; color:var(--text-secondary, #444); font-size:0.98rem">
      <p style="margin-bottom:18px">
        This Privacy Policy explains how Webjinny collects, uses, and protects information when you
        use our website.
      </p>

      <h3 style="font-size:1.05rem; font-weight:700; margin:24px 0 10px">Information We Collect</h3>
      <p style="margin-bottom:18px">
        When you submit a property listing or an enquiry, we collect basic contact details such as
        your name, phone number, and email address so that property owners and interested buyers
        can connect with each other.
      </p>

      <h3 style="font-size:1.05rem; font-weight:700; margin:24px 0 10px">How We Use Your Information</h3>
      <p style="margin-bottom:18px">
        Contact information submitted through enquiry or listing forms is used only to facilitate
        communication between buyers, tenants, and property owners. We do not sell your personal
        information to third parties.
      </p>

      <h3 style="font-size:1.05rem; font-weight:700; margin:24px 0 10px">Cookies</h3>
      <p style="margin-bottom:18px">
        We use basic session cookies to keep the site functioning correctly (for example, to keep
        admin users logged in). We do not use cookies for third-party advertising tracking.
      </p>

      <h3 style="font-size:1.05rem; font-weight:700; margin:24px 0 10px">Contact Us</h3>
      <p>
        If you have questions about this Privacy Policy, please reach out at
        <a href="mailto:inquiry@webjinny.xyz" style="color:var(--primary, #002FA7); font-weight:600">
          inquiry@webjinny.xyz
        </a>.
      </p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
