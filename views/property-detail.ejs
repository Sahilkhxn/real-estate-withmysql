<%
function formatPrice(n) {
  if (n >= 10000000) return '₹' + (n / 10000000).toFixed(2) + ' Cr';
  if (n >= 100000) return '₹' + (n / 100000).toFixed(2) + ' L';
  if (n >= 1000) return '₹' + (n / 1000).toFixed(0) + 'K';
  return '₹' + n.toLocaleString('en-IN');
}
const priceLabels = { total: '', per_month: ' / month', per_sqft: ' / sq.ft' };
const waNumber = property.whatsappNumber || property.contactNumber;
const waMsg = encodeURIComponent(`Hi! I'm interested in your property: ${property.title}\n\nPlease share more details.`);
%>
<%- include('partials/header', { title: property.title }) %>

<div class="container">
  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="/">Home</a>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/properties">Properties</a>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span><%= property.title.length > 40 ? property.title.slice(0,40) + '...' : property.title %></span>
  </div>

  <div class="page-section">
    <div class="detail-grid">
      <!-- LEFT COLUMN -->
      <div>
        <!-- Photo Gallery -->
        <% if (property.photos && property.photos.length > 0) { %>
        <div class="gallery">
          <div class="gallery-main">
            <img id="galleryMain" src="/uploads/<%= property.photos[0] %>" alt="<%= property.title %>" />
            <% if (property.photos.length > 1) { %>
            <button class="prev-btn" id="prevBtn">‹</button>
            <button class="next-btn" id="nextBtn">›</button>
            <div class="gallery-counter">1 / <%= property.photos.length %></div>
            <% } %>
          </div>
          <% if (property.photos.length > 1) { %>
          <div class="gallery-thumbs">
            <% property.photos.forEach((photo, i) => { %>
            <img src="/uploads/<%= photo %>" 
                 data-full="/uploads/<%= photo %>"
                 alt="Photo <%= i+1 %>" 
                 class="<%= i === 0 ? 'active' : '' %>" />
            <% }) %>
          </div>
          <% } %>
        </div>
        <% } else { %>
        <div class="gallery" style="height:300px;display:flex;align-items:center;justify-content:center;background:var(--bg-page);border-radius:var(--radius)">
          <div class="card-img-placeholder" style="height:auto">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:64px;height:64px;color:var(--border)">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <path d="m21 15-5-5L5 21"/>
            </svg>
            <span style="color:var(--text-light)">No photos uploaded</span>
          </div>
        </div>
        <% } %>

        <!-- Property details -->
        <div class="detail-info">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px">
            <div>
              <div class="detail-price"><%= formatPrice(property.price) %><% if(property.priceType !== 'total'){ %><span style="font-size:1rem;font-weight:400;color:var(--text-light)"><%= priceLabels[property.priceType] %></span><% } %></div>
              <div class="detail-price-type">
                <span class="badge <%= property.type === 'rent' ? 'badge-green' : 'badge-blue' %>"><%= property.type ? property.type.charAt(0).toUpperCase() + property.type.slice(1) : '' %></span>
                &nbsp;
                <span class="badge <%= property.status === 'available' ? 'badge-green' : property.status === 'sold' ? 'badge-red' : 'badge-orange' %>">
                  <%= property.status ? property.status.charAt(0).toUpperCase() + property.status.slice(1) : '' %>
                </span>
              </div>
            </div>
            <div style="text-align:right">
              <div style="font-size:0.78rem;color:var(--text-light)">Listed</div>
              <div style="font-size:0.88rem;font-weight:600"><%= new Date(property.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></div>
            </div>
          </div>

          <h1 class="detail-title"><%= property.title %></h1>
          <div class="detail-location">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue-primary)" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <%= property.location.area %>, <%= property.location.city %>, <%= property.location.state %>
            <% if (property.location.pincode) { %>— <%= property.location.pincode %><% } %>
          </div>

          <!-- Specs -->
          <div class="detail-specs">
            <% if (property.bedrooms > 0) { %>
            <div class="spec-item">
              <span class="spec-val"><%= property.bedrooms %></span>
              <div class="spec-label">Bedrooms</div>
            </div>
            <% } %>
            <% if (property.bathrooms > 0) { %>
            <div class="spec-item">
              <span class="spec-val"><%= property.bathrooms %></span>
              <div class="spec-label">Bathrooms</div>
            </div>
            <% } %>
            <% if (property.area) { %>
            <div class="spec-item">
              <span class="spec-val"><%= property.area %></span>
              <div class="spec-label">Sq. Feet</div>
            </div>
            <% } %>
            <div class="spec-item">
              <span class="spec-val" style="font-size:0.9rem"><%= property.propertyCategory ? property.propertyCategory.charAt(0).toUpperCase() + property.propertyCategory.slice(1) : '—' %></span>
              <div class="spec-label">Category</div>
            </div>
          </div>

          <!-- Amenities -->
          <% if (property.amenities && property.amenities.length > 0) { %>
          <div class="amenities-list mb-24">
            <% property.amenities.forEach(a => { %>
            <span class="amenity-tag"><%= a %></span>
            <% }) %>
          </div>
          <% } %>

          <!-- Description -->
          <div class="detail-desc">
            <h3>About this Property</h3>
            <p><%= property.description %></p>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN — Contact Sidebar -->
      <div>
        <div class="contact-card">
          <div class="contact-card-title">📞 Contact Owner</div>

          <div class="contact-btns">
            <a href="https://wa.me/<%= waNumber.replace(/\D/g,'') %>?text=<%= waMsg %>" 
               target="_blank" class="btn btn-whatsapp btn-lg w-full">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/>
              </svg>
              WhatsApp Owner
            </a>

            <a href="tel:<%= property.contactNumber %>" class="btn btn-call btn-lg w-full">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.5 12.75 19.79 19.79 0 011.5 4.1 2 2 0 013.5 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 9.91a16 16 0 006.29 6.29l1.28-1.28a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
              Call: <%= property.contactNumber %>
            </a>
          </div>

          <!-- Enquiry Form -->
          <div class="enquiry-form">
            <h4>📩 Send Enquiry</h4>
            <form id="enquiryForm">
              <input type="hidden" name="propertyId" value="<%= property._id %>"/>
              <div class="form-group">
                <label>Your Name *</label>
                <input type="text" name="name" class="form-control" placeholder="Full name" required />
              </div>
              <div class="form-group">
                <label>Phone Number *</label>
                <input type="tel" name="phone" class="form-control" placeholder="+91 98765 43210" required />
              </div>
              <div class="form-group">
                <label>Email (optional)</label>
                <input type="email" name="email" class="form-control" placeholder="your@email.com" />
              </div>
              <div class="form-group">
                <label>Message *</label>
                <textarea name="message" class="form-control" rows="3" required
                  placeholder="I'm interested in this property. Please contact me.">I'm interested in this property. Please share more details.</textarea>
              </div>
              <button type="submit" class="btn btn-primary w-full">Send Enquiry</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
