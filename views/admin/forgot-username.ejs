<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Forgot Username | Webjinny</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<div class="login-page">
  <div class="login-card">
    <div style="text-align:center;margin-bottom:28px">
      <div style="font-size:2rem;font-weight:800;margin-bottom:6px">
        <span style="background:var(--blue);color:white;padding:4px 10px;border-radius:8px">Webjinny</span>
      </div>
      <h1>Forgot Username</h1>
      <p>Enter your admin email to receive username</p>
    </div>

    <% if (error) { %><div class="flash flash-error"><%= error %></div><% } %>
    <% if (success) { %><div class="flash flash-success"><%= success %></div><% } %>

    <form action="/admin/forgot-username" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>"/> 
        <label class="form-label">Admin Email</label>
        <input type="email" name="email" class="form-control"
               placeholder="inquiry@webjinny.xyz" required
               style="background:white"/>
      </div>
      <button type="submit" class="btn btn-primary w-full mt-16" style="justify-content:center;padding:14px">
        Send Username
      </button>
    </form>

    <div style="text-align:center;margin-top:20px">
      <a href="/admin/login" style="color:var(--text-light);font-size:0.85rem">← Back to Login</a>
    </div>
  </div>
</div>
</body>
</html>