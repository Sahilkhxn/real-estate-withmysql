<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Reset Password | Webjinny</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<div class="login-page">
  <div class="login-card">
    <div style="text-align:center;margin-bottom:28px">
      <div style="font-size:2rem;font-weight:800;margin-bottom:6px">
        <span style="background:var(--blue);color:white;padding:4px 10px;border-radius:8px">Webjinny</span>
      </div>
      <h1>Reset Password</h1>
      <p>Enter your new password</p>
    </div>

    <% if (error) { %><div class="flash flash-error"><%= error %></div><% } %>

    <form action="/admin/reset-password" method="POST">
      <input type="hidden" name="email" value="<%= email %>"/>
      <input type="hidden" name="otp" value="<%= otp %>"/>
      <div class="form-group">
        <label class="form-label">New Password</label>
        <input type="password" name="password" class="form-control"
               placeholder="••••••••" required minlength="6"
               style="background:white"/>
      </div>
      <div class="form-group">
        <label class="form-label">Confirm Password</label>
        <input type="password" name="confirmPassword" class="form-control"
               placeholder="••••••••" required minlength="6"
               style="background:white"/>
      </div>
      <button type="submit" class="btn btn-primary w-full mt-16" style="justify-content:center;padding:14px">
        Reset Password
      </button>
    </form>

    <div style="text-align:center;margin-top:20px">
      <a href="/admin/login" style="color:var(--text-light);font-size:0.85rem">← Back to Login</a>
    </div>
  </div>
</div>
</body>
</html>