<%
function formatPrice(n) {
  if (n >= 10000000) return '₹' + (n / 10000000).toFixed(1) + ' Cr';
  if (n >= 100000) return '₹' + (n / 100000).toFixed(1) + ' L';
  return '₹' + n.toLocaleString('en-IN');
}
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Admin Dashboard | Webjinny</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="sidebar-logo"><span>Webjinny</span> Admin</div>
    <ul class="sidebar-nav">
      <li><a href="/admin/dashboard" class="active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Dashboard
      </a></li>
      <li><a href="/admin/properties">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Properties
      </a></li>
      <li><a href="/admin/properties/new">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        Add Property
      </a></li>
    </ul>
    <div class="sidebar-footer">
      <a href="/" style="color:rgba(255,255,255,0.5);font-size:0.82rem;display:block;margin-bottom:8px">← View Website</a>
      <a href="/admin/logout" class="btn btn-danger btn-sm w-full" style="justify-content:center">Logout</a>
    </div>
  </aside>

  <main class="admin-main">
    <% if (typeof flashSuccess !== 'undefined' && flashSuccess) { %>
    <div class="flash flash-success">✓ <%= flashSuccess %></div>
    <% } %>

    <div class="admin-topbar">
      <h1 class="admin-page-title">Dashboard</h1>
      <a href="/admin/properties/new" class="btn btn-primary">+ Add Property</a>
    </div>

    <!-- Stats -->
    <div class="stats-cards">
      <div class="stat-card">
        <div class="stat-card-icon blue">🏠</div>
        <div>
          <div class="stat-card-val"><%= stats.total %></div>
          <div class="stat-card-lbl">Total Properties</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon green">✅</div>
        <div>
          <div class="stat-card-val"><%= stats.available %></div>
          <div class="stat-card-lbl">Available</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon red">🔴</div>
        <div>
          <div class="stat-card-val"><%= stats.sold %></div>
          <div class="stat-card-lbl">Sold / Rented</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon orange">⭐</div>
        <div>
          <div class="stat-card-val"><%= stats.featured %></div>
          <div class="stat-card-lbl">Featured</div>
        </div>
      </div>
    </div>

    <!-- Recent properties -->
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">Recent Listings</h2>
        <a href="/admin/properties" class="btn btn-outline btn-sm">View All</a>
      </div>

      <% if (recentProperties && recentProperties.length > 0) { %>
      <div style="overflow-x:auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Photo</th>
              <th>Title</th>
              <th>Location</th>
              <th>Price</th>
              <th>Type</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% recentProperties.forEach(p => { %>
            <tr>
              <td>
                <% if (p.photos && p.photos.length > 0) { %>
                  <img src="/uploads/<%= p.photos[0] %>" alt="" class="table-img"/>
                <% } else { %>
                  <div class="table-img" style="background:var(--bg-page);display:flex;align-items:center;justify-content:center;color:var(--text-light);font-size:0.7rem">No img</div>
                <% } %>
              </td>
              <td style="max-width:200px"><strong><%= p.title.slice(0,50) %><%= p.title.length > 50 ? '...' : '' %></strong></td>
              <td><%= p.location.area %>, <%= p.location.city %></td>
              <td><strong><%= formatPrice(p.price) %></strong></td>
              <td><span class="badge badge-blue"><%= p.type %></span></td>
              <td>
                <span class="badge <%= p.status === 'available' ? 'badge-green' : p.status === 'sold' ? 'badge-red' : 'badge-orange' %>">
                  <%= p.status %>
                </span>
              </td>
              <td>
                <div class="table-actions">
                  <a href="/admin/properties/<%= p._id %>/edit" class="btn btn-outline btn-sm">Edit</a>
                  <a href="/property/<%= p._id %>" target="_blank" class="btn btn-sm" style="background:var(--bg-page);color:var(--text-mid)">View</a>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <div class="empty-state" style="padding:32px">
        <h3>No properties yet</h3>
        <p>Add your first property listing.</p>
        <a href="/admin/properties/new" class="btn btn-primary mt-16">Add Property</a>
      </div>
      <% } %>
    </div>
  </main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
