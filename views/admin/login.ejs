<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Admin Login | Webjinny</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<div class="login-page">
  <div class="login-card">
    <div style="text-align:center;margin-bottom:28px">
      <div style="font-size:2rem;font-weight:800;color:var(--blue-primary);margin-bottom:6px">
        <span style="background:var(--blue-primary);color:white;padding:4px 10px;border-radius:8px">Webjinny</span>
      </div>
      <h1>Admin Panel</h1>
      <p>Sign in to manage property listings</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="flash flash-error"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
    <div class="flash flash-success"><%= success %></div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="form-group">
        <label class="form-label">Username</label>
        <input type="text" name="username" class="form-control" 
               placeholder="admin" required autocomplete="username" 
               style="background:white"/>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" 
               placeholder="••••••••" required autocomplete="current-password"
               style="background:white"/>
      </div>
      <button type="submit" class="btn btn-primary w-full mt-16" style="justify-content:center;padding:14px">
        Sign In
      </button>
    </form>

    <div style="text-align:center;margin-top:20px">
      <a href="/" style="color:var(--text-light);font-size:0.85rem">← Back to website</a>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
