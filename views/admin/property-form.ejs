function loadDistricts(state) {
  const select = document.getElementById('districtSelect');
  const currentCity = '<%= isEdit ? property.location.city : "" %>';
  select.innerHTML = '<option value="">Select District</option>';
  if (districts[state]) {
    districts[state].forEach(d => {
      const opt = document.createElement('option');
      opt.value = d;
      opt.text = d;
      if (currentCity === d) opt.selected = true;
      select.appendChild(opt);
    });
  }
}

function handleCategory() {
  const cat = document.getElementById('categorySelect').value;
  const showBedroom = ['apartment','house','villa','pg'].includes(cat);
  document.getElementById('bedroomSection').style.display = showBedroom ? 'block' : 'none';
  document.getElementById('areaOnlySection').style.display = showBedroom ? 'none' : 'block';
}

document.addEventListener('DOMContentLoaded', () => {
  handleCategory();
  <% if (isEdit && property.location && property.location.state) { %>
  loadDistricts('<%= property.location.state %>');
  <% } %>
});

// Drag & drop
const dropArea = document.getElementById('dropArea');
['dragenter','dragover'].forEach(e => {
  dropArea.addEventListener(e, ev => { ev.preventDefault(); dropArea.classList.add('dragging'); });
});
['dragleave','drop'].forEach(e => {
  dropArea.addEventListener(e, ev => { ev.preventDefault(); dropArea.classList.remove('dragging'); });
});
dropArea.addEventListener('drop', ev => {
  const files = ev.dataTransfer.files;
  const input = document.getElementById('photoInput');
  const dt = new DataTransfer();
  for (const f of files) dt.items.add(f);
  input.files = dt.files;
  previewPhotos(input);
});

function previewPhotos(input) {
  const container = document.getElementById('newPhotoPreview');
  container.innerHTML = '';
  Array.from(input.files).slice(0, 10).forEach((file, i) => {
    const reader = new FileReader();
    reader.onload = e => {
      const div = document.createElement('div');
      div.className = 'photo-preview-item';
      div.innerHTML = `<img src="${e.target.result}" alt="Photo ${i+1}"/>`;
      container.appendChild(div);
    };
    reader.readAsDataURL(file);
  });
}

function removeExistingPhoto(filename, container) {
  container.remove();
  document.querySelectorAll('.existing-photo-input').forEach(inp => {
    if (inp.value === filename) inp.remove();
  });
}
</script>
