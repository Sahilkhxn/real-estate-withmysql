<%- include('partials/header', { title: 'List Your Property' }) %>

<div class="container">
  <div class="breadcrumb">
    <a href="/">Home</a>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span>List Your Property</span>
  </div>

  <div class="page-section" style="max-width:800px;margin:0 auto">
    <div style="text-align:center;margin-bottom:32px">
      <h1 style="font-size:1.8rem;font-weight:900;letter-spacing:-0.5px;margin-bottom:8px">List Your Property</h1>
      <p style="color:var(--text-light);font-size:0.95rem">Fill in the details below. Our team will review and publish your listing within 24 hours.</p>
    </div>

    <!-- Step indicator -->
    <div style="display:flex;justify-content:center;align-items:center;gap:12px;margin-bottom:28px">
      <div id="dot1" style="width:34px;height:34px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.9rem;flex-shrink:0">1</div>
      <div style="flex:1;max-width:80px;height:2px;background:var(--border)" id="stepLine"></div>
      <div id="dot2" style="width:34px;height:34px;border-radius:50%;background:var(--border);color:var(--text-light);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.9rem;flex-shrink:0">2</div>
      <div style="font-size:0.82rem;color:var(--text-light)" id="stepLabel">Fill Details → Add Photos</div>
    </div>

    <!-- Error box -->
    <div id="formError" class="flash flash-error" style="display:none;margin-bottom:16px"></div>

    <!-- ════════════ SECTION 1: Details Form ════════════ -->
    <div id="sectionDetails">
      <form id="detailsForm">

        <div class="admin-card">
          <div class="admin-card-header"><h2 class="admin-card-title">Your Details</h2></div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Your Name *</label>
              <input type="text" name="name" class="form-control" required placeholder="Full name"/>
            </div>
            <div class="form-group">
  <label class="form-label">Your Phone *</label>
  <input type="tel" name="phone" class="form-control" required 
    placeholder="Phone no."
    oninput="this.value=this.value.replace(/[^0-9]/g,'').slice(0,10)"
    minlength="10" maxlength="10" title="Exactly 10 digit number"/>
</div>
            <div class="form-group">
  <label class="form-label">Your Email *</label>
  <input type="email" name="ownerEmail" class="form-control" required placeholder="yourname@gmail.com"/>
</div>

          </div>
        </div>

        <div class="admin-card">
          <div class="admin-card-header"><h2 class="admin-card-title">Property Details</h2></div>
          <div class="form-group">
            <label class="form-label">Property Title *</label>
            <input type="text" name="title" class="form-control" required placeholder="e.g. 3 BHK Apartment in Malviya Nagar"/>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Listing Type *</label>
              <select name="type" class="form-control" required>
                <option value="">Select type</option>
                <!-- <option value="buy">Buy</option> -->
                <option value="rent">Rent</option>
                <option value="sell">Sell</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Property Category</label>
              <select name="propertyCategory" id="categorySelect" class="form-control" onchange="handleCategory()">
                <option value="apartment">Apartment</option>
                <option value="house">House</option>
                <option value="villa">Villa</option>
                <option value="plot">Plot / Land</option>
                <option value="commercial">Commercial</option>
                <option value="pg">PG / Hostel</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Description</label>
            <textarea name="description" class="form-control" rows="4" placeholder="Describe your property..."></textarea>
          </div>
        </div>

        <div class="admin-card">
          <div class="admin-card-header"><h2 class="admin-card-title">Price</h2></div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Price (₹) *</label>
              <input type="number" name="price" class="form-control" required placeholder="e.g. 4500000" min="0"/>
            </div>
            <div class="form-group">
              <label class="form-label">Price Type</label>
              <select name="priceType" class="form-control">
                <option value="total">Total Price</option>
                <option value="per_month">Per Month</option>
                <option value="per_sqft">Per Sq.ft</option>
              </select>
            </div>
          </div>
        </div>

        <div class="admin-card">
          <div class="admin-card-header"><h2 class="admin-card-title">Location</h2></div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">State *</label>
              <select name="state" id="stateSelect" class="form-control" required onchange="loadDistricts(this.value)">
                <option value="">Select State</option>
                <option value="Andhra Pradesh">Andhra Pradesh</option>
                <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                <option value="Assam">Assam</option>
                <option value="Bihar">Bihar</option>
                <option value="Chhattisgarh">Chhattisgarh</option>
                <option value="Goa">Goa</option>
                <option value="Gujarat">Gujarat</option>
                <option value="Haryana">Haryana</option>
                <option value="Himachal Pradesh">Himachal Pradesh</option>
                <option value="Jharkhand">Jharkhand</option>
                <option value="Karnataka">Karnataka</option>
                <option value="Kerala">Kerala</option>
                <option value="Madhya Pradesh">Madhya Pradesh</option>
                <option value="Maharashtra">Maharashtra</option>
                <option value="Manipur">Manipur</option>
                <option value="Meghalaya">Meghalaya</option>
                <option value="Mizoram">Mizoram</option>
                <option value="Nagaland">Nagaland</option>
                <option value="Odisha">Odisha</option>
                <option value="Punjab">Punjab</option>
                <option value="Rajasthan">Rajasthan</option>
                <option value="Sikkim">Sikkim</option>
                <option value="Tamil Nadu">Tamil Nadu</option>
                <option value="Telangana">Telangana</option>
                <option value="Tripura">Tripura</option>
                <option value="Uttar Pradesh">Uttar Pradesh</option>
                <option value="Uttarakhand">Uttarakhand</option>
                <option value="West Bengal">West Bengal</option>
                <option value="Delhi">Delhi</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">District *</label>
              <select name="city" id="districtSelect" class="form-control" required>
                <option value="">Select State First</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Area / Locality *</label>
              <input type="text" name="locationArea" class="form-control" required placeholder="e.g. Malviya Nagar"/>
            </div>
            <div class="form-group">
              <label class="form-label">Pincode</label>

              <input type="number" name="pincode" class="form-control" 
  placeholder="302001"
  oninput="if(this.value.length>6) this.value=this.value.slice(0,6)"
  min="100000" max="999999" title="Exactly 6 digit pincode"/>

            </div>
          </div>
        </div>

        <div class="admin-card">
          <div class="admin-card-header"><h2 class="admin-card-title">Property Specs</h2></div>
          <div id="bedroomSection">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Bedrooms</label>
                <input type="number" name="bedrooms" class="form-control" min="0" placeholder="0" value="0"/>
              </div>
              <div class="form-group">
                <label class="form-label">Bathrooms</label>
                <input type="number" name="bathrooms" class="form-control" min="0" placeholder="0" value="0"/>
              </div>
              <div class="form-group">
                <label class="form-label">Area (Sq. Ft)</label>
                <input type="number" name="propArea" class="form-control" min="0" placeholder="1200"/>
              </div>
            </div>
          </div>
          <div id="areaOnlySection" style="display:none">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Area (Sq. Ft)</label>
                <input type="number" name="propArea" class="form-control" min="0" placeholder="1200"/>
              </div>
            </div>
          </div>
          <div class="form-group" style="margin-top:14px">
            <label class="form-label">Amenities (comma separated)</label>
            <input type="text" name="amenities" class="form-control" placeholder="Parking, Lift, 24/7 Water, Power Backup"/>
          </div>
        </div>

        <div class="admin-card">
          <div class="admin-card-header"><h2 class="admin-card-title">Contact Details</h2></div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Contact Number *</label>

              <input type="number" name="contactNumber" class="form-control" required 
  placeholder="contact Number" 
  oninput="if(this.value.length>10) this.value=this.value.slice(0,10)"
  min="1000000000" max="9999999999" title="Exactly 10 digit number"/>

            </div>
            <div class="form-group">
              <label class="form-label">WhatsApp Number</label>

              <input type="number" name="whatsappNumber" class="form-control"
  placeholder="whatsapp Number"
  oninput="if(this.value.length>10) this.value=this.value.slice(0,10)"
  min="1000000000" max="9999999999" title="Exactly 10 digit number"/>


            </div>
          </div>
        </div>

        <!-- STEP 1 SUBMIT BUTTON -->
        <div style="text-align:center;margin-bottom:32px">
          <button type="submit" id="step1Btn" class="btn btn-primary btn-lg" style="padding:14px 48px;font-size:1rem">
            Save & Add Photos →
          </button>
          <p style="margin-top:10px;font-size:0.82rem;color:var(--text-light)">You can add photos in the next step (optional).</p>
        </div>

      </form>
    </div>

    <!-- ════════════ SECTION 2: Photos (hidden initially) ════════════ -->
    <div id="sectionPhotos" style="display:none">

      <div class="admin-card" style="border:2px solid var(--primary)">
        <div class="admin-card-header" style="background:var(--primary-light, #eff6ff)">
          <h2 class="admin-card-title" style="color:var(--primary)">✅ Details Saved! Now Add Photos</h2>
        </div>
        <p style="color:var(--text-light);margin-bottom:20px;font-size:0.92rem">
          Photos optional hain — inse listing attractive banti hai. Max 5 photos, 5MB each.
        </p>

        <div class="photo-upload-area" id="dropArea" onclick="document.getElementById('photoInput').click()" style="cursor:pointer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:40px;height:40px;margin-bottom:8px">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          <p>Click to select photos</p>
          <small>JPEG, PNG, WebP · Max 5MB each · Up to 5 photos</small>
        </div>

        <input type="file" id="photoInput" accept="image/jpeg,image/jpg,image/png,image/webp" multiple style="display:none"
          onchange="if(this.files.length>5){alert('Max 5 photos allowed');this.value='';return;} previewPhotos(this)"/>

        <div class="photo-preview-grid" id="photoPreview" style="margin-top:12px"></div>

        <!-- Upload progress bar -->
        <div id="uploadProgress" style="display:none;margin-top:16px">
          <div style="background:var(--border);border-radius:20px;height:8px;overflow:hidden">
            <div id="progressBar" style="background:#2563eb;height:100%;width:0%;transition:width 0.4s;border-radius:20px"></div>

          </div>
          <p id="progressText" style="font-size:0.82rem;color:var(--text-light);margin-top:6px;text-align:center">Uploading...</p>
        </div>

        <div id="uploadResult" style="margin-top:10px;font-size:0.9rem"></div>
      </div>

      <!-- STEP 2 BUTTONS -->
      <div style="text-align:center;margin-bottom:32px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <button id="uploadBtn" onclick="uploadPhotos()" class="btn btn-primary btn-lg" style="padding:14px 36px;font-size:1rem">
          Upload Photos & Finish
        </button>
        <!-- <button onclick="skipAndFinish()" class="btn" style="padding:14px 36px;font-size:1rem;border:1px solid var(--border)">
          Skip Photos
        </button> -->
      </div>
    </div>

    <!-- ════════════ FINAL SUCCESS ════════════ -->
    <div id="sectionSuccess" style="display:none;text-align:center;padding:48px 20px">
      <div style="font-size:3.5rem;margin-bottom:16px">🎉</div>
      <h2 style="font-weight:900;font-size:1.6rem;margin-bottom:10px">Property Submitted!</h2>
      <p style="color:var(--text-light);margin-bottom:28px;font-size:0.95rem">Our team will review and publish your listing within 24 hours.</p>
      <a href="/" class="btn btn-primary" style="padding:12px 36px;font-size:1rem">Back to Home</a>
    </div>

  </div>
</div>

<%- include('partials/footer') %>

