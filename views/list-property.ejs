  "Goa": ["North Goa","South Goa"],
  "Manipur": ["Bishnupur","Churachandpur","Imphal East","Imphal West","Senapati","Thoubal","Ukhrul"],
  "Meghalaya": ["East Garo Hills","East Khasi Hills","North Garo Hills","Ri Bhoi","South Garo Hills","West Garo Hills","West Khasi Hills"],
  "Tripura": ["Dhalai","Gomati","Khowai","North Tripura","Sepahijala","South Tripura","Unakoti","West Tripura"],
  "Arunachal Pradesh": ["Anjaw","Changlang","East Kameng","East Siang","Lohit","Longding","Lower Dibang Valley","Lower Subansiri","Namsai","Papum Pare","Tawang","Tirap","Upper Siang","Upper Subansiri","West Kameng","West Siang"],
  "Nagaland": ["Dimapur","Kiphire","Kohima","Longleng","Mokokchung","Mon","Peren","Phek","Tuensang","Wokha","Zunheboto"],
  "Mizoram": ["Aizawl","Champhai","Kolasib","Lawngtlai","Lunglei","Mamit","Serchhip","Siaha"],
  "Sikkim": ["East Sikkim","North Sikkim","South Sikkim","West Sikkim"]
};

function loadDistricts(state) {
  const select = document.getElementById('districtSelect');
  select.innerHTML = '<option value="">Select District</option>';
  if (districts[state]) {
    districts[state].forEach(d => {
      const opt = document.createElement('option');
      opt.value = d;
      opt.text = d;
      select.appendChild(opt);
    });
  }
}

function handleCategory() {
  const cat = document.getElementById('categorySelect').value;
  const showBedroom = ['apartment','house','villa','pg'].includes(cat);
  document.getElementById('bedroomSection').style.display = showBedroom ? 'block' : 'none';
  document.getElementById('areaOnlySection').style.display = showBedroom ? 'none' : 'block';
}

function previewPhotos(input) {
  const container = document.getElementById('newPhotoPreview');
  container.innerHTML = '';
  Array.from(input.files).slice(0, 10).forEach((file, i) => {
    const reader = new FileReader();
    reader.onload = e => {
      const div = document.createElement('div');
      div.className = 'photo-preview-item';
      div.innerHTML = `<img src="${e.target.result}" alt="Photo ${i+1}"/>`;
      container.appendChild(div);
    };
    reader.readAsDataURL(file);
  });
}

document.addEventListener('DOMContentLoaded', () => {
  handleCategory();
});
</script>
