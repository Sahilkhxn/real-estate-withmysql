function loadDistricts(state) {
  const select = document.getElementById('districtSelect');
  select.innerHTML = '<option value="">Select District</option>';
  if (districts[state]) {
    districts[state].forEach(d => {
      const opt = document.createElement('option');
      opt.value = d; opt.text = d;
      select.appendChild(opt);
    });
  }
}

function handleCategory() {
  const cat = document.getElementById('categorySelect').value;
  const showBedroom = ['apartment','house','villa','pg'].includes(cat);
  document.getElementById('bedroomSection').style.display = showBedroom ? 'block' : 'none';
  document.getElementById('areaOnlySection').style.display = showBedroom ? 'none' : 'block';
}

function previewPhotos(input) {
  const container = document.getElementById('photoPreview');
  container.innerHTML = '';
  Array.from(input.files).slice(0, 5).forEach((file, i) => {
    const reader = new FileReader();
    reader.onload = e => {
      const div = document.createElement('div');
      div.className = 'photo-preview-item';
      div.innerHTML = `<img src="${e.target.result}" alt="Photo ${i+1}" style="width:100%;height:100%;object-fit:cover;border-radius:6px"/>`;
      container.appendChild(div);
    };
    reader.readAsDataURL(file);
  });
}

document.addEventListener('DOMContentLoaded', () => { handleCategory(); });

// ── STEP 1: Details submit ──
document.getElementById('detailsForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('step1Btn');
  const errEl = document.getElementById('formError') || document.createElement('div');

  btn.textContent = 'Saving...';
  btn.disabled = true;
  errEl.style.display = 'none';

  const body = new URLSearchParams(new FormData(this)).toString();

  try {
    const res = await fetch('/list-property', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body
    });
    const data = await res.json();

    if (!data.success) {
      errEl.textContent = data.error || 'Something went wrong. Please try again.';
      errEl.style.display = 'block';
      btn.textContent = 'Save & Add Photos →';
      btn.disabled = false;
      window.scrollTo({ top: 0, behavior: 'smooth' });
      return;
    }

    savedPropertyId = data.propertyId;

    // Step indicator update
    document.getElementById('dot1').textContent = '✓';
    document.getElementById('dot1').style.background = '#22c55e';
    document.getElementById('dot2').style.background = 'var(--primary)';
    document.getElementById('dot2').style.color = '#fff';
    document.getElementById('stepLabel').textContent = 'Details Saved ✓ → Add Photos';

    // Show photo section, hide details
    document.getElementById('sectionDetails').style.display = 'none';
    document.getElementById('sectionPhotos').style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });

  } catch (err) {
    errEl.textContent = 'Network error. Please check your connection and try again.';
    errEl.style.display = 'block';
    btn.textContent = 'Save & Add Photos →';
    btn.disabled = false;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
});

// ── STEP 2: Upload photos ──
async function uploadPhotos() {
  const input = document.getElementById('photoInput');
  if (!input.files.length) {
    alert('Pehle photos select karo!');
    return;
  }

  const btn = document.getElementById('uploadBtn');
  btn.textContent = 'Uploading...';
  btn.disabled = true;
  document.getElementById('uploadProgress').style.display = 'block';

  let prog = 10;
  const interval = setInterval(() => {
    prog += (90 - prog) * 0.15;
    document.getElementById('progressBar').style.width = Math.min(prog, 88) + '%';
    document.getElementById('progressText').textContent = `Uploading... ${Math.round(Math.min(prog, 88))}%`;
  }, 600);

  const formData = new FormData();
  formData.append('propertyId', savedPropertyId);
  Array.from(input.files).forEach(f => formData.append('photos', f));

  try {
    const res = await fetch('/list-property/upload-photos', { method: 'POST', body: formData });
    const result = await res.json();
    clearInterval(interval);
    document.getElementById('progressBar').style.width = '100%';
    document.getElementById('progressText').textContent = 'Done!';

    if (result.success) {
      showSuccess();
    } else {
      document.getElementById('uploadResult').innerHTML = '<span style="color:red">⚠️ Upload failed. Try again or skip.</span>';
      btn.textContent = 'Retry Upload';
      btn.disabled = false;
    }
  } catch (err) {
    clearInterval(interval);
    document.getElementById('uploadResult').innerHTML = '<span style="color:red">⚠️ Network error. Try again or skip.</span>';
    btn.textContent = 'Retry Upload';
    btn.disabled = false;
  }
}

function skipAndFinish() { showSuccess(); }

function showSuccess() {
  document.getElementById('sectionPhotos').style.display = 'none';
  document.getElementById('sectionSuccess').style.display = 'block';
  document.getElementById('stepLabel').textContent = 'All Done! ✓';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>
